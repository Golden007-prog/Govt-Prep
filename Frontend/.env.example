# Copy to `.env.local` and fill in. NEVER commit real values (.env* is git-ignored).
# All blanks are fine for local-first development — the app falls back to Dexie + BYOK.

# --- Hosted backend (Supabase). The anon/publishable key is safe to expose (RLS protects data). ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Local/desktop mode: URL of the Node/Fastify backend (transcripts + optional claude -p). ---
VITE_LOCAL_BACKEND_URL=http://localhost:8787

# --- Model IDs (override per environment). Claude-only architecture (v3). ---
VITE_CLAUDE_MODEL_ROUTINE=claude-haiku-4-5-20251001
VITE_CLAUDE_MODEL_GRADING=claude-sonnet-4-6

# --- DEV-ONLY: pre-seed the BYOK Anthropic key so you don't retype it each run. ---
# NEVER set in CI/deploy builds — VITE_ vars are baked into the public bundle.
VITE_ANTHROPIC_API_KEY=
