# Copy to `.env.local` and fill in. NEVER commit real values (.env* is git-ignored).
# All blanks are fine for local-first development — the app falls back to Dexie + BYOK.

# --- Hosted backend (Supabase). Leave blank until the project is provisioned (via Supabase MCP). ---
# The anon key is publishable (Row-Level Security protects data). Operator LLM keys are NOT here —
# they live in Supabase Edge Function secrets.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Local/desktop mode: URL of the Node/Fastify backend that runs `claude -p` + transcripts. ---
VITE_LOCAL_BACKEND_URL=http://localhost:8787

# --- Model IDs (override per environment). Current recommended ids shown; confirm before deploy. ---
VITE_CLAUDE_MODEL_ROUTINE=claude-haiku-4-5-20251001
VITE_CLAUDE_MODEL_GRADING=claude-sonnet-4-6
VITE_GEMINI_MODEL=gemini-2.5-flash
